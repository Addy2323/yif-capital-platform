generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  name                String
  password            String
  /// E.164 format, e.g. +255712345678
  phoneNumber         String?            @unique @map("phone_number")
  lastPhonePromptDate DateTime?          @map("last_phone_prompt_date") @db.Date
  isVerified          Boolean            @default(false) @map("is_verified")
  role                UserRole           @default(FREE)
  avatar              String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  failedLoginAttempts Int                @default(0) @map("failed_login_attempts")
  lockoutUntil        DateTime?          @map("lockout_until")
  accessLogs          AccessAttemptLog[]
  accessTokens        AccessToken[]
  enrollments         Enrollment[]
  payments            Payment[]
  portfolios          Portfolio[]

  // LMS Expert Platform Relations
  expertProfile          ExpertProfile?
  lmsEnrollments         LmsCourseEnrollment[]
  lessonProgress         LessonProgress[]
  quizAttempts           QuizAttempt[]
  bookingsAsUser         ExpertBooking[]         @relation("BookingUser")
  certificates           Certificate[]
  notifications          Notification[]
  readinessResults       ReadinessResult[]
  lmsPayments            LmsPayment[]
  sessions               UserSession[]
  instructorApplications InstructorApplication[] @relation("ApplicantUser")
  reviewedApplications   InstructorApplication[] @relation("ApplicationReviewer")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

model Enrollment {
  id         String             @id @default(uuid())
  userId     String
  courseId   String
  status     SubscriptionStatus @default(ACTIVE)
  enrolledAt DateTime           @default(now())
  expiresAt  DateTime?
  paymentId  String?            @unique
  payment    Payment?           @relation(fields: [paymentId], references: [id])
  user       User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model LiveSession {
  id               String             @id @default(uuid())
  courseId         String
  title            String
  shortDescription String?
  description      String?
  meetingUrl       String?
  recordingUrl     String?
  scheduledStart   DateTime
  scheduledEnd     DateTime
  status           String             @default("scheduled")
  currency         String             @default("TZS")
  isFree           Boolean            @default(true)
  price            Float              @default(0)
  accessLogs       AccessAttemptLog[]
  accessTokens     AccessToken[]
  payments         Payment[]

  @@index([courseId])
  @@index([scheduledStart])
}

model AccessToken {
  id                String      @id @default(uuid())
  tokenHash         String      @unique
  userId            String
  sessionId         String
  deviceFingerprint String
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime    @default(now())
  session           LiveSession @relation(fields: [sessionId], references: [id])
  user              User        @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@index([userId])
  @@index([sessionId])
}

model AccessAttemptLog {
  id                String       @id @default(uuid())
  userId            String?
  sessionId         String?
  ipAddress         String?
  deviceFingerprint String?
  userAgent         String?
  status            String
  reason            String?
  createdAt         DateTime     @default(now())
  session           LiveSession? @relation(fields: [sessionId], references: [id])
  user              User?        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

model Payment {
  id                String       @id @default(uuid())
  userId            String
  amount            Float
  currency          String       @default("TZS")
  provider          String
  providerReference String?      @unique
  status            String
  plan              String
  createdAt         DateTime     @default(now())
  completedAt       DateTime?
  sessionId         String?
  enrollment        Enrollment?
  session           LiveSession? @relation(fields: [sessionId], references: [id])
  user              User         @relation(fields: [userId], references: [id])

  @@index([sessionId])
}

enum UserRole {
  FREE
  PRO
  INSTITUTIONAL
  ADMIN
  EXPERT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model PricingPlan {
  id          String   @id @default(uuid())
  planId      String   @unique // "free", "pro", "institutional"
  name        String
  price       Float
  currency    String   @default("TZS")
  period      String?
  description String
  features    Json // Array of {name: string, included: boolean}
  cta         String
  href        String
  popular     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

/// One-time passwords for phone verification (hashed at rest)
model Otp {
  id          String   @id @default(uuid())
  phoneNumber String   @map("phone_number")
  otpHash     String   @map("otp_code")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phoneNumber])
}

/// Admin bulk SMS campaigns (Beem Africa)
model BulkSmsCampaign {
  id               String    @id @default(uuid())
  message          String
  groupsTargeted   String[]
  recipientCount   Int
  deliveredCount   Int       @default(0)
  failedCount      Int       @default(0)
  status           String
  scheduledAt      DateTime?
  sentAt           DateTime?
  estimatedCostTzs Int?
  errorMessage     String?
  createdAt        DateTime  @default(now())

  @@index([createdAt])
  @@index([status])
}

// ============================================
// FUND ANALYTICS PLATFORM - CORE MODELS
// ============================================

// Fund Type Enum
enum FundType {
  BALANCED
  FIXED_INCOME
  INCOME
  BOND
  FUND_FAMILY
  MONEY_MARKET
  EQUITY
}

// Risk Level Enum
enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

// Compliance Status Enum
enum ComplianceStatus {
  COMPLIANT
  WATCH
  BREACH
}

// Fund Manager Information
model Manager {
  id          String   @id @default(uuid())
  name        String   @unique
  logoUrl     String?
  description String?
  website     String?
  funds       Fund[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Fund Registry - Core fund information
model Fund {
  id            String   @id @default(uuid())
  fundId        String   @unique // URL-friendly ID (e.g., 'utt-amis')
  fundSlug      String   @unique // Alternative slug
  fundName      String
  fundType      FundType
  managerId     String?
  manager       Manager? @relation(fields: [managerId], references: [id])
  managerName   String? // [MIGRATION] Restored for data transition
  description   String
  logoUrl       String?
  inceptionDate DateTime
  baseCurrency  String   @default("TZS")
  benchmarkId   String?
  benchmarkName String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  dailySummaries     FundDailySummary[]
  performanceMetrics FundPerformance[]
  portfolioData      FundPortfolio[]
  riskMetrics        FundRisk[]
  incomeData         FundIncome[]
  financials         FundFinancials[]
  complianceChecks   FundCompliance[]
  attributionData    FundAttribution[]
  benchmarkingData   FundBenchmarking[]
  navHistory         FundNavHistory[]
  holdings           FundHolding[]

  @@index([fundId])
  @@index([fundType])
  @@index([isActive])
}

// NAV History - Daily NAV tracking
model FundDailySummary {
  id              String   @id @default(uuid())
  fundId          String
  date            DateTime
  schemeName      String?
  nav             Float
  dailyReturn     Float
  aum             Float
  volatility      Float
  salePrice       Float?
  repurchasePrice Float?
  createdAt       DateTime @default(now())

  // Relation
  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date, schemeName])
  @@index([fundId, date, schemeName])
}

// NAV History Extended - For chart data
model FundNavHistory {
  id               String   @id @default(uuid())
  fundId           String
  date             DateTime
  nav              Float
  navChange        Float?
  navChangePct     Float?
  aum              Float
  unitsOutstanding Float?
  createdAt        DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date])
  @@index([fundId, date])
}

// Module 1: Overview Dashboard Data
model FundPerformance {
  id        String   @id @default(uuid())
  fundId    String
  date      DateTime
  timeframe String // 1W, 1M, 3M, 6M, YTD, 1Y, 3Y, 5Y, SINCE_INCEPTION

  // Overview KPIs
  aum                  Float?
  aumChangePct         Float?
  nav                  Float?
  navChange1d          Float?
  navChangeYtd         Float?
  returnMtd            Float?
  returnYtd            Float?
  return1y             Float?
  returnSinceInception Float?
  expenseRatio         Float?
  cashPositionPct      Float?

  // Summary Stats
  trackingError Float?
  alpha         Float?
  beta          Float?
  sharpeRatio   Float?
  volatility1y  Float?
  maxDrawdown   Float?

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date, timeframe])
  @@index([fundId, date])
}

// Module 3: Portfolio Composition
model FundPortfolio {
  id     String   @id @default(uuid())
  fundId String
  date   DateTime

  // Asset Allocation (stored as JSON array)
  assetAllocation Json? // [{ label, pct }]

  // Sector Allocation (stored as JSON array)
  sectorAllocation Json? // [{ label, pct }]

  // Geographic Allocation (stored as JSON array)
  geoAllocation Json? // [{ country, pct }]

  // Market Cap Exposure (stored as JSON array)
  marketCapExposure Json? // [{ label, pct }]

  // Top Holdings Count
  totalHoldings Int?

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date])
  @@index([fundId, date])
}

// Individual Holdings
model FundHolding {
  id     String   @id @default(uuid())
  fundId String
  date   DateTime

  holdingName String
  assetType   String?
  weightPct   Float
  value       Float?
  changePct   Float?
  isin        String?
  sector      String?

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@index([fundId, date])
  @@index([fundId, holdingName])
}

// Module 4: Risk Analytics
model FundRisk {
  id        String   @id @default(uuid())
  fundId    String
  date      DateTime
  timeframe String

  // Risk KPIs
  maxDrawdown       Float?
  var95             Float? // Value at Risk 95%
  cvar95            Float? // Conditional VaR
  downsideDeviation Float?
  volatility1y      Float?
  sharpeRatio       Float?
  sortinoRatio      Float?
  riskLevel         RiskLevel?
  riskScore         Int? // 0-100 normalized

  // Bond/Fixed Income specific
  durationYears Float?
  creditRatings Json? // [{ rating, pct }]

  // Stress Tests (stored as JSON array)
  stressTests Json? // [{ scenario_name, impact_pct, description }]

  // Drawdown Series (stored as JSON array)
  drawdownSeries Json? // [{ date, drawdown_pct }]

  // Volatility Series (stored as JSON array)
  volatilitySeries Json? // [{ date, rolling_vol_pct }]

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date, timeframe])
  @@index([fundId, date])
}

// Module 5: Income & Cash Flow
model FundIncome {
  id     String   @id @default(uuid())
  fundId String
  date   DateTime
  period String // MTD, QTD, YTD, 1Y

  // Income KPIs
  dailyLiquidityRatio Float?
  interestIncome      Float?
  dividendIncome      Float?
  totalIncome         Float?
  expenseRatio        Float?
  netInvestmentIncome Float?
  cashInflows         Float?
  cashOutflows        Float?

  // Maturity Profile (stored as JSON array) - for bond/fixed income
  maturityProfile Json? // [{ bucket_label, value, pct_of_aum }]

  // Cash Flow Timeline (stored as JSON array)
  cashFlowTimeline Json? // [{ date, inflow, outflow, net }]

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date, period])
  @@index([fundId, date])
}

// Module 6: Financial Statements
model FundFinancials {
  id     String   @id @default(uuid())
  fundId String
  date   DateTime
  period String // Q1, Q2, Q3, Q4, FY

  // Income Statement (stored as JSON)
  incomeStatement Json? // { interest_income, dividend_income, unrealized_gains_losses, realized_gains_losses, management_fees, custody_fees, other_expenses, net_investment_income, total_comprehensive_income, expense_ratio_trend, net_income_margin_pct, income_yield_pct, fee_drag_pct }

  // Balance Sheet (stored as JSON)
  balanceSheet Json? // { assets: { cash, investments, receivables }, total_assets, liabilities: { payables, mgmt_fees }, total_liabilities, net_assets, units_outstanding, nav_per_unit, liquidity_ratio, net_assets_trend }

  // Cash Flow Statement (stored as JSON)
  cashFlow Json? // { operating: { investment_income_cash, expenses_paid, net }, investing: { purchases, proceeds, net }, financing: { units_issued, units_redeemed, distributions, net }, net_cash_movement, waterfall, net_movement_timeline, sub_redemption_ratio }

  // Ratios & Reconciliation
  ratios Json? // { nav_net_assets_variance, cash_coverage, distribution_coverage, accrual_vs_cash_variance }

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date, period])
  @@index([fundId, date])
}

// Module 7: Benchmark & Peer Comparison
model FundBenchmarking {
  id        String   @id @default(uuid())
  fundId    String
  date      DateTime
  timeframe String

  // Benchmark Comparison
  fundReturn       Float?
  benchmarkReturn  Float?
  alpha            Float?
  beta             Float?
  trackingError    Float?
  informationRatio Float?
  benchmarkName    String?

  // Peer Comparison (stored as JSON array)
  peers Json? // [{ fund_id, fund_name, return_pct, volatility, sharpe_ratio, max_drawdown, rank }]

  // Radar Chart Axes (stored as JSON array)
  radarAxes Json? // [{ axis_label, fund_score, benchmark_score }]

  // Ranking
  rankPercentile Int?

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date, timeframe])
  @@index([fundId, date])
}

// Module 8: Compliance & Policy Monitoring
model FundCompliance {
  id     String   @id @default(uuid())
  fundId String
  date   DateTime

  // Overall Status
  overallStatus ComplianceStatus
  greenCount    Int              @default(0)
  amberCount    Int              @default(0)
  redCount      Int              @default(0)

  // Compliance Checks (stored as JSON array)
  checks Json? // [{ rule_name, rule_type, current_value, limit_value, format, status, last_checked_at, breach_history }]

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date])
  @@index([fundId, date])
}

// Module 9: Attribution Analysis
model FundAttribution {
  id        String   @id @default(uuid())
  fundId    String
  date      DateTime
  timeframe String

  // Attribution Effects
  totalReturn             Float?
  benchmarkReturn         Float?
  assetAllocationEffect   Float?
  securitySelectionEffect Float?
  interactionEffect       Float?
  activeReturn            Float?

  // Waterfall Data (stored as JSON array)
  waterfall Json? // [{ label, value, type }]

  createdAt DateTime @default(now())

  fund Fund @relation(fields: [fundId], references: [fundId])

  @@unique([fundId, date, timeframe])
  @@index([fundId, date])
}

// ============================================
// DSE STOCK MARKET DATA
// ============================================

model Stock {
  id            String   @id @default(uuid())
  symbol        String   @unique
  name          String
  description   String?
  sector        String?
  industry      String?
  website       String?
  logoUrl       String?
  marketCap     Float?
  dividendYield Float?
  peRatio       Float?
  eps           Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  prices     StockPriceHistory[]
  portfolios PortfolioStock[]

  @@index([symbol])
}

model StockPriceHistory {
  id              String   @id @default(uuid())
  stockId         String
  price           Float
  change          Float    @default(0)
  changePct       Float    @default(0)
  marketCap       Float?
  volume          Int?
  revenue         Float?
  peRatio         Float?
  dividendYield   Float?
  payoutRatio     Float?
  netIncome       Float?
  eps             Float?
  ytdChange       Float?
  change1w        Float?
  change1m        Float?
  change6m        Float?
  change1y        Float?
  change3y        Float?
  change5y        Float?
  psRatio         Float?
  pbRatio         Float?
  roe             Float?
  roa             Float?
  debtToEquity    Float?
  dps             Float?
  dividendGrowth  Float?
  payoutFrequency String?
  operatingIncome Float?
  fcf             Float?
  fcfPerShare     Float?
  sharesOut       Float?
  averageVolume   Float?
  beta            Float?
  rsi             Float?
  timestamp       DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, timestamp])
  @@index([stockId])
  @@index([timestamp])
}

model EconomicIndicator {
  id            String   @id @default(uuid())
  title         String   @unique // e.g., "Inflation Rate"
  value         String // e.g., "3.3%"
  label         String // e.g., "January 2026"
  change        String? // e.g., "▲+0.12%"
  previousValue String? // e.g., "Prev: 3.3%"
  sortOrder     Int      @default(0)
  updatedAt     DateTime @updatedAt
}

model DseMarketSummary {
  id            String   @id @default("1")
  indexValue    Float // DSE All Share Index value
  change        Float
  changePercent Float
  // Additional DSE indices
  tsiValue      Float? // Tanzania Share Index
  tsiChange     Float?
  bfiValue      Float? // Banks, Finance & Investments Index
  bfiChange     Float?
  iaValue       Float? // Industrial & Allied Index
  iaChange      Float?
  perf1M        String?
  perf3M        String?
  perfYTD       String?
  perf1Y        String?
  perf2Y        String?
  valueTraded   String?
  volume        String?
  transactions  String?
  marketCap     String?
  turnOver      String?
  deals         String?
  date          String?
  updatedAt     DateTime @updatedAt
}

// [MIGRATION] Restored temporarily to prevent data loss on production server
model DseStock {
  id        String   @id @default(uuid())
  symbol    String
  name      String?
  price     Float?
  change    Float?
  changePct Float?
  marketCap String?
  scrapedAt DateTime @default(now())

  // [MIGRATION] Restored columns to prevent data loss on production server
  averageVolume   Float?
  beta            Float?
  change1m        Float?
  change1w        Float?
  change1y        Float?
  change3y        Float?
  change5y        Float?
  change6m        Float?
  dividendGrowth  Float?
  dividendYield   Float?
  dps             Float?
  eps             Float?
  fcf             Float?
  fcfPerShare     Float?
  industry        String?
  netIncome       Float?
  operatingIncome Float?
  payoutFrequency String?
  payoutRatio     Float?
  pbRatio         Float?
  peRatio         Float?
  psRatio         Float?
  revenue         Float?
  roa             Float?
  roe             Float?
  rsi             Float?
  sector          String?
  sharesOut       Float?
  updatedAt       DateTime @updatedAt
  volume          Int?
  ytdChange       Float?

  @@index([symbol])
  @@index([scrapedAt])
}

// ============================================
// PORTFOLIO MODELS
// ============================================

model Portfolio {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id])
  stocks PortfolioStock[]
  funds  PortfolioFund[]

  @@index([userId])
}

model PortfolioStock {
  id           String    @id @default(uuid())
  portfolioId  String
  stockId      String? // [MIGRATION] Made optional for data preservation
  ticker       String? // [MIGRATION] Restored for data transition
  name         String? // [MIGRATION] Restored for data transition
  sector       String? // [MIGRATION] Restored for data transition
  qty          Float
  buyPrice     Float
  currentPrice Float? // [MIGRATION] Restored for data transition
  dividend     Float? // [MIGRATION] Restored for data transition
  buyDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stock     Stock?    @relation(fields: [stockId], references: [id])

  @@index([portfolioId])
  @@index([stockId])
}

model PortfolioFund {
  id           String    @id @default(uuid())
  portfolioId  String
  name         String
  type         String?
  invested     Float
  currentValue Float
  rate         Float?    @default(0)
  startDate    DateTime?
  maturityDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
}

// ============================================
// LMS INVESTMENT EXPERT PLATFORM
// ============================================

// Expert Approval Status
enum ExpertApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// Expert Specialization Categories
enum ExpertCategory {
  STOCK_MARKET
  BONDS_FIXED_INCOME
  MUTUAL_FUNDS
  PERSONAL_FINANCE
  REAL_ESTATE_ALT
  ENTREPRENEURSHIP_BUSINESS
  INSURANCE_RISK
  SACCOS_COOPERATIVE
}

// Session Type for Bookings
enum SessionType {
  ONLINE
  PHYSICAL
  GROUP
  VIP_PRIVATE
}

// Booking Status
enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Payout Request Status
enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
}

// Course Status
enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Course Level
enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// Investor Readiness Level
enum InvestorLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// Notification Type
enum NotificationType {
  BOOKING
  PAYMENT
  SESSION_REMINDER
  CERTIFICATE
  COURSE_UPDATE
  EXPERT_RESPONSE
  SYSTEM
}

// Expert Profile — Full expert information
model ExpertProfile {
  id                  String               @id @default(uuid())
  userId              String               @unique
  bio                 String?
  headline            String?
  experienceYears     Int                  @default(0)
  cvUrl               String?
  certificationsUrl   String?
  nationalIdUrl       String?
  nationalIdVerified  Boolean              @default(false)
  approvalStatus      ExpertApprovalStatus @default(PENDING)
  approvalNote        String?
  rating              Float                @default(0)
  totalReviews        Int                  @default(0)
  totalStudents       Int                  @default(0)
  totalEarnings       Float                @default(0)
  hourlyRate          Float                @default(0)
  currency            String               @default("TZS")
  location            String?
  languages           String[]             @default(["English", "Swahili"])
  specializations     ExpertCategory[]
  isAvailableOnline   Boolean              @default(true)
  isAvailablePhysical Boolean              @default(false)
  physicalAddress     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses        LmsCourse[]
  availability   ExpertAvailability[]
  bookings       ExpertBooking[]
  payoutRequests PayoutRequest[]

  @@index([approvalStatus])
  @@index([userId])
}

// LMS Course
model LmsCourse {
  id                 String         @id @default(uuid())
  expertId           String
  title              String
  slug               String         @unique
  description        String
  shortDescription   String?
  thumbnailUrl       String?
  instructorPhotoUrl String?
  category           ExpertCategory
  level              CourseLevel    @default(BEGINNER)
  price              Float          @default(0)
  currency           String         @default("TZS")
  isFree             Boolean        @default(false)
  status             CourseStatus   @default(DRAFT)
  totalDuration      Int            @default(0) // minutes
  totalLessons       Int            @default(0)
  rating             Float          @default(0)
  totalEnrollments   Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  enrollmentDeadline DateTime?

  expert       ExpertProfile         @relation(fields: [expertId], references: [id], onDelete: Cascade)
  modules      CourseModule[]
  enrollments  LmsCourseEnrollment[]
  certificates Certificate[]
  lmsPayments  LmsPayment[]

  @@index([expertId])
  @@index([category])
  @@index([status])
  @@index([slug])
}

// Course Module — Section within a course
model CourseModule {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  course  LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quizzes Quiz[]

  @@index([courseId])
}

// Lesson — Individual content unit
model Lesson {
  id          String   @id @default(uuid())
  moduleId    String
  title       String
  description String?
  videoUrl    String?
  pdfUrl      String?
  content     String? // Rich text content
  duration    Int      @default(0) // minutes
  sortOrder   Int      @default(0)
  isFree      Boolean  @default(false) // Preview lesson
  createdAt   DateTime @default(now())

  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([moduleId])
}

// LMS Course Enrollment
model LmsCourseEnrollment {
  id               String    @id @default(uuid())
  userId           String
  courseId         String
  progress         Float     @default(0) // 0-100 percentage
  completedLessons Int       @default(0)
  totalLessons     Int       @default(0)
  isCompleted      Boolean   @default(false)
  completedAt      DateTime?
  paymentId        String?   @unique
  enrolledAt       DateTime  @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  LmsCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payment LmsPayment? @relation(fields: [paymentId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// Lesson Progress — Per-lesson tracking
model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  isCompleted Boolean   @default(false)
  watchedPct  Float     @default(0) // 0-100
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([isCompleted])
}

// Quiz
model Quiz {
  id           String   @id @default(uuid())
  moduleId     String
  title        String
  description  String?
  passingScore Int      @default(70)
  createdAt    DateTime @default(now())

  module    CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([moduleId])
}

// Quiz Question — MCQ
model QuizQuestion {
  id           String  @id @default(uuid())
  quizId       String
  question     String
  options      Json // ["Option A", "Option B", "Option C", "Option D"]
  correctIndex Int // 0-3
  explanation  String?
  sortOrder    Int     @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

// Quiz Attempt
model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  quizId      String
  score       Float // Percentage 0-100
  passed      Boolean  @default(false)
  answers     Json // [{ questionId, selectedIndex, correct }]
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

// Expert Availability — Weekly time slots
model ExpertAvailability {
  id        String   @id @default(uuid())
  expertId  String
  dayOfWeek Int // 0=Sunday, 6=Saturday
  startTime String // "09:00"
  endTime   String // "17:00"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  expert ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId])
  @@index([dayOfWeek])
}

// Expert Booking — Session booking
model ExpertBooking {
  id            String         @id @default(uuid())
  userId        String
  expertId      String
  sessionType   SessionType
  category      ExpertCategory
  topic         String?
  scheduledDate DateTime
  startTime     String // "10:00"
  endTime       String // "11:00"
  status        BookingStatus  @default(PENDING)
  price         Float          @default(0)
  currency      String         @default("TZS")
  meetingUrl    String? // meet.yifcapital.co.tz link
  location      String? // For physical meetings
  notes         String?
  paymentId     String?        @unique
  cancelReason  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user    User          @relation("BookingUser", fields: [userId], references: [id], onDelete: Cascade)
  expert  ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  payment LmsPayment?   @relation(fields: [paymentId], references: [id])

  @@index([userId])
  @@index([expertId])
  @@index([scheduledDate])
  @@index([status])
}

// Certificate — Auto-generated on course completion
model Certificate {
  id              String   @id @default(uuid())
  userId          String
  courseId        String
  certificateCode String   @unique // e.g. "YIF-CERT-2026-XXXXX"
  qrCodeData      String? // QR verification URL
  issuedAt        DateTime @default(now())

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([certificateCode])
}

// Notification — In-app notifications
model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  actionUrl String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// LMS Payment — Course/Booking payments (reuses Snippe)
model LmsPayment {
  id                String    @id @default(uuid())
  userId            String
  amount            Float
  currency          String    @default("TZS")
  provider          String    @default("snippe")
  providerReference String?   @unique
  status            String    @default("pending") // pending, success, failed
  paymentType       String // "course" or "booking"
  courseId          String?
  description       String?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     LmsCourse?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  enrollment LmsCourseEnrollment?
  booking    ExpertBooking?

  @@index([userId])
  @@index([status])
  @@index([providerReference])
}

// Expert Payout Request
model PayoutRequest {
  id             String       @id @default(uuid())
  expertId       String
  amount         Float // gross amount requested (100%)
  expertAmount   Float // 80% to expert
  platformFee    Float // 20% to platform
  status         PayoutStatus @default(PENDING)
  payoutMethod   String // MOBILE_MONEY | BANK_TRANSFER
  mobileProvider String?
  mobileNumber   String?
  bankName       String?
  accountNumber  String?
  accountName    String?
  branchName     String?
  adminNote      String?
  requestedAt    DateTime     @default(now())
  processedAt    DateTime?
  processedBy    String?

  expert ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@index([expertId])
  @@index([status])
  @@index([requestedAt])
}

// Investment Readiness Quiz
model ReadinessQuiz {
  id          String   @id @default(uuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  questions ReadinessQuestion[]
  results   ReadinessResult[]
}

// Readiness Quiz Question
model ReadinessQuestion {
  id        String @id @default(uuid())
  quizId    String
  question  String
  options   Json // [{ text, points }]
  sortOrder Int    @default(0)

  quiz ReadinessQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

// User Readiness Result
model ReadinessResult {
  id          String        @id @default(uuid())
  userId      String
  quizId      String
  totalScore  Int
  level       InvestorLevel
  answers     Json // [{ questionId, selectedIndex, points }]
  completedAt DateTime      @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz ReadinessQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
}

enum InstructorApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  MORE_INFO
}

model InstructorApplication {
  id                String                      @id @default(uuid())
  userId            String                      @map("user_id")
  user              User                        @relation("ApplicantUser", fields: [userId], references: [id], onDelete: Cascade)
  occupation        String
  company           String?
  experienceYears   Int                         @map("experience_years")
  expertise         String
  courseTitle       String                      @map("course_title")
  courseCategory    String                      @map("course_category")
  courseDescription String                      @map("course_description")
  education         String
  certifications    String?
  linkedin          String?
  website           String?
  cvUrl             String?                     @map("cv")
  certificatesUrl   String?                     @map("certificates")
  motivation        String
  status            InstructorApplicationStatus @default(PENDING)
  adminNote         String?                     @map("admin_note")
  reviewedBy        String?                     @map("reviewed_by")
  reviewer          User?                       @relation("ApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?                   @map("reviewed_at")
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
}
