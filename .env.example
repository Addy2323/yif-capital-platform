# =============================================================================
# YIF Capital — environment template (NO SECRETS HERE)
# =============================================================================
# Copy to `.env` and fill in real values locally. Never commit `.env`.
#
# API key safety (OpenAI / Google):
# - Use one key per developer where possible; invite teammates via your provider
#   dashboard so they get their own keys — do not share production keys.
# - Never put API keys in browsers, mobile apps, or NEXT_PUBLIC_* variables.
#   This app calls Gemini/OpenAI only from Next.js API routes / server code.
# - Rotate keys if they are ever pasted into chat, tickets, or screenshots.
# =============================================================================

# --- Google Gemini (Generative Language API) — server only ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override default model (see src/ai/geminiGenerate.ts)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL_FALLBACK=
# GEMINI_429_RETRIES=3

# Same as GEMINI_API_KEY for some setups (optional)
# GOOGLE_GENERATIVE_AI_API_KEY=

# --- OpenAI — server only; keys must not reach the client bundle ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL_FALLBACK=
# OPENAI_429_RETRIES=3

# Try Gemini first, then OpenAI if the first provider fails (or openai_first)
AI_PROVIDER_ORDER=gemini_first

# Portfolio insight popups (optional)
# INSIGHT_MOVE_PCT=2.5
