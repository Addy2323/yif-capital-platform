# =============================================================================
# YIF Capital — environment template (NO SECRETS HERE)
# =============================================================================
# Copy to `.env` and fill in real values locally. Never commit `.env`.
#
# API key safety:
# - Use one key per developer where possible; invite teammates via OpenAI
#   so they get their own keys — do not share production keys.
# - Never put API keys in browsers, mobile apps, or NEXT_PUBLIC_* variables.
#   This app calls OpenAI only from Next.js API routes / server code.
# - Rotate keys if they are ever pasted into chat, tickets, or screenshots.
# =============================================================================

# --- OpenAI (Chat Completions) — server only ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional; default is gpt-3.5-turbo (broad compatibility). Use gpt-4o-mini if your account supports it.
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_MODEL_FALLBACK=
# OPENAI_429_RETRIES=3

# Portfolio insight popups (optional)
# INSIGHT_MOVE_PCT=2.5
